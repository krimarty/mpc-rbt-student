<root BTCPP_format="4">

  <BehaviorTree ID="WarehouseMission">
    <Sequence name="main_mission">

      <!-- 1. Vyžádejte si pickup task od warehouse manageru -->
      <GetTaskService service_name="/get_pickup_task"
                      manipulator_id="{manipulator_id}"/>

      <!-- 2. Převeďte ID manipulátoru na souřadnice -->
      <LookupPose location_id="{manipulator_id}"
                  x="{goal_x}" y="{goal_y}"/>

      <!-- 3. Navigujte k manipulátoru -->
      <NavigateToPoseAction action_name="/go_to_goal"
                            x="{goal_x}" y="{goal_y}"/>

      <!-- 4. Potvrzení nakládky -->
      <ConfirmLoadingService service_name="/confirm_loading"/>

      <!-- 5. Zjištění cílového skladu -->
      <GetDropoffService service_name="/get_dropoff_location"
                         storage_id="{storage_id}"/>

      <!-- 6. Převod ID skladu na souřadnice -->
      <LookupPose location_id="{storage_id}"
                  x="{goal_x}" y="{goal_y}"/>

      <!-- 7. Navigace do skladu -->
      <NavigateToPoseAction action_name="/go_to_goal"
                            x="{goal_x}" y="{goal_y}"/>

      <!-- 8. Návrat na startovní pozici -->
      <NavigateToPoseAction action_name="/go_to_goal"
                            x="-0.5" y="0.0"/>

    </Sequence>
  </BehaviorTree>

</root>
